# =============================================
# XOUND - Variables de entorno
# =============================================
# En el servidor: copia esto como .env y llena los valores reales.
#   cp .env.example .env
#   nano .env

# Supabase - Obtén el JDBC URL en:
#   Supabase Dashboard → Project Settings → Database → Connection string → JDBC
SUPABASE_URL=jdbc:postgresql://db.XXXXXXXXXXXX.supabase.co:5432/postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=tu-password-de-supabase

# JWT Secret (mínimo 32 caracteres, usa algo aleatorio)
JWT_SECRET=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
